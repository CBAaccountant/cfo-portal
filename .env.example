# QBO OAuth (from developer.intuit.com)
QBO_CLIENT_ID=your_client_id_here
QBO_CLIENT_SECRET=your_client_secret_here
REDIRECT_URI=https://your-railway-url.railway.app/callback
QBO_ENVIRONMENT=production

# App
SESSION_SECRET=pick-any-long-random-string
NODE_ENV=production
PORT=3000

# Database (auto-provided by Railway PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Token encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=your-64-char-hex-string-here
